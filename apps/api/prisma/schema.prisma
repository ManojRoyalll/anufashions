generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum ExpenseType {
  RENT
  ELECTRICITY
  TRANSPORT
  MARKETING
  SALARY
  PACKAGING
  MISC
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model PriceRange {
  id        String    @id @default(cuid())
  name      String    @unique
  minPrice  Decimal   @db.Decimal(12, 2)
  maxPrice  Decimal   @db.Decimal(12, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Supplier {
  id                  String     @id @default(cuid())
  name                String
  phone               String?
  email               String?
  address             String?
  productsSupplied    String?
  outstandingPayments Decimal    @default(0) @db.Decimal(12, 2)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  products            Product[]
  purchases           Purchase[]

  @@index([name])
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  phone              String?   @unique
  address            String?
  favoriteCategories String?
  totalSpend         Decimal   @default(0) @db.Decimal(12, 2)
  lifetimeValue      Decimal   @default(0) @db.Decimal(12, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sales              Sale[]

  @@index([name])
}

model Product {
  id            String      @id @default(cuid())
  code          String      @unique
  barcode       String?     @unique
  name          String
  categoryId    String
  supplierId    String?
  priceRangeId  String?
  discountLimit Float?
  purchasePrice Decimal     @db.Decimal(12, 2)
  sellingPrice  Decimal     @db.Decimal(12, 2)
  mrp           Decimal?    @db.Decimal(12, 2)
  color         String?
  size          String?
  material      String?
  quantity      Int         @default(0)
  imageUrl      String?
  datePurchased DateTime?
  stockStatus   StockStatus @default(IN_STOCK)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  category      Category     @relation(fields: [categoryId], references: [id])
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  priceRange    PriceRange?  @relation(fields: [priceRangeId], references: [id])
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@index([name])
  @@index([categoryId])
}

model Purchase {
  id           String         @id @default(cuid())
  purchaseDate DateTime
  supplierId   String
  invoiceNo    String
  totalAmount  Decimal        @db.Decimal(12, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]

  @@index([purchaseDate])
}

model PurchaseItem {
  id           String   @id @default(cuid())
  purchaseId   String
  productId    String
  quantity     Int
  costPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  purchase     Purchase @relation(fields: [purchaseId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id             String        @id @default(cuid())
  saleDate       DateTime
  customerId     String?
  paymentMethod  PaymentMethod
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  gst            Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  revenue        Decimal       @db.Decimal(12, 2)
  cogs           Decimal       @db.Decimal(12, 2)
  grossProfit    Decimal       @db.Decimal(12, 2)
  netProfit      Decimal       @db.Decimal(12, 2)
  marginPercent  Decimal       @db.Decimal(7, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer       Customer?     @relation(fields: [customerId], references: [id])
  items          SaleItem[]

  @@index([saleDate])
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  productId     String
  quantity      Int
  unitPrice     Decimal  @db.Decimal(12, 2)
  purchasePrice Decimal  @db.Decimal(12, 2)
  lineTotal     Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  sale          Sale     @relation(fields: [saleId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
}

model Expense {
  id          String      @id @default(cuid())
  date        DateTime
  type        ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([date])
}

model BusinessMetric {
  id                String   @id @default(cuid())
  totalInvestment   Decimal  @default(0) @db.Decimal(12, 2)
  totalProfit       Decimal  @default(0) @db.Decimal(12, 2)
  totalRevenue      Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt         DateTime @updatedAt
}
