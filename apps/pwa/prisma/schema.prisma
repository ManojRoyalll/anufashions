generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  DISABLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum ExpenseType {
  RENT
  ELECTRICITY
  TRANSPORT
  PACKAGING
  SALARY
  MARKETING
  INTERNET
  MISCELLANEOUS
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?      @unique
  passwordHash String
  role         UserRole     @default(ADMIN)
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model BusinessSetting {
  id           String   @id @default("singleton")
  businessName String   @default("Anu Fashions")
  defaultLang  String   @default("en")
  currency     String   @default("INR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  imageUrl    String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    Product[]
}

model Supplier {
  id                String    @id @default(cuid())
  name              String
  phone             String?
  address           String?
  gstNumber         String?
  productsSupplied  String?
  paymentStatus     String?   @default("PENDING")
  outstandingAmount Decimal   @default(0) @db.Decimal(14, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  products          Product[]
  purchases         Purchase[]
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  phone              String?   @unique
  address            String?
  notes              String?
  totalOrders        Int       @default(0)
  totalSpend         Decimal   @default(0) @db.Decimal(14, 2)
  lifetimeValue      Decimal   @default(0) @db.Decimal(14, 2)
  favoriteCategories String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sales              Sale[]
}

model Product {
  id            String       @id @default(cuid())
  productCode   String       @unique
  barcode       String?      @unique
  qrCode        String?
  name          String
  categoryId    String
  supplierId    String?
  purchasePrice Decimal      @db.Decimal(12, 2)
  sellingPrice  Decimal      @db.Decimal(12, 2)
  mrp           Decimal?     @db.Decimal(12, 2)
  color         String?
  material      String?
  size          String?
  quantity      Int          @default(0)
  imageUrls     String[]
  datePurchased DateTime?
  notes         String?
  status        EntityStatus @default(ACTIVE)
  stockStatus   StockStatus  @default(IN_STOCK)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
}

model Purchase {
  id                String         @id @default(cuid())
  purchaseDate      DateTime
  supplierId        String
  invoiceNumber     String
  transportCost     Decimal        @default(0) @db.Decimal(12, 2)
  additionalCharges Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal        @db.Decimal(14, 2)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  supplier          Supplier       @relation(fields: [supplierId], references: [id])
  items             PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  costPrice  Decimal  @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(14, 2)

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id            String        @id @default(cuid())
  saleDate      DateTime
  customerId    String?
  paymentMethod PaymentMethod
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(14, 2)
  revenue       Decimal       @db.Decimal(14, 2)
  cogs          Decimal       @db.Decimal(14, 2)
  grossProfit   Decimal       @db.Decimal(14, 2)
  netProfit     Decimal       @db.Decimal(14, 2)
  marginPercent Decimal       @db.Decimal(7, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer      Customer?     @relation(fields: [customerId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  productId     String
  quantity      Int
  unitPrice     Decimal  @db.Decimal(12, 2)
  purchasePrice Decimal  @db.Decimal(12, 2)
  lineTotal     Decimal  @db.Decimal(14, 2)

  sale          Sale     @relation(fields: [saleId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
}

model Expense {
  id          String      @id @default(cuid())
  date        DateTime
  amount      Decimal     @db.Decimal(12, 2)
  type        ExpenseType
  description String?
  receiptUrl  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
